rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Imagens de produtos, seções da home e lojas são públicas para leitura;
    // apenas usuários autenticados podem gravar (admins fazem upload logados).
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
