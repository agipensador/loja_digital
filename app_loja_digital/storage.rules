rules_version = '2';

// Storage multi-tenant: imagens ficam em stores/{storeId}/... e só a equipe
// da loja (masters/admins, lidos do Firestore) pode gravar.
service firebase.storage {
  match /b/{bucket}/o {

    function isStoreTeam(storeId) {
      return request.auth != null && (
        request.auth.uid in firestore.get(
          /databases/(default)/documents/stores/$(storeId)).data.masters ||
        request.auth.uid in firestore.get(
          /databases/(default)/documents/stores/$(storeId)).data.admins
      );
    }

    // Caminho novo (multi-tenant): stores/{storeId}/products|home|locations/...
    match /stores/{storeId}/{allPaths=**} {
      allow read: if true;
      allow write: if isStoreTeam(storeId);
    }

    // Caminhos antigos (pré multi-tenant): leitura mantida para as imagens
    // já publicadas; escrita bloqueada — novos uploads vão para stores/...
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
