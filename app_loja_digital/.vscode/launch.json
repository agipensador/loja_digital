{
    // Cada configuração roda o MESMO código apontando para uma loja
    // (tenant) diferente via --dart-define=STORE_ID.
    // Terminal: flutter run --dart-define=STORE_ID=loja_ju
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Loja Ju (dev)",
            "request": "launch",
            "type": "dart",
            "args": ["--dart-define=STORE_ID=loja_ju"]
        },
        {
            "name": "Loja Val (dev)",
            "request": "launch",
            "type": "dart",
            "args": ["--dart-define=STORE_ID=loja_val"]
        },
        {
            "name": "Loja Ju (release)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "args": ["--dart-define=STORE_ID=loja_ju"]
        },
        {
            "name": "Loja Val (release)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "args": ["--dart-define=STORE_ID=loja_val"]
        }
    ]
}
